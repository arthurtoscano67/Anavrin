# Core network
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Optional: websocket endpoint for the same provider
SOLANA_WS_URL=

# Jupiter REST base (quote + swap-instructions)
JUPITER_API_BASE=https://quote-api.jup.ag/v6

# Bot behavior
ARB_RUN_ONCE=false
ARB_DRY_RUN=true
ARB_AUTO_EXECUTE=false
ARB_REQUOTE_BEFORE_EXECUTE=true
ARB_PREFLIGHT_SIMULATION_ENABLED=true

# Scan cadence
ARB_CYCLE_INTERVAL_MS=1000
ARB_QUOTE_TIMEOUT_MS=1500
ARB_MAX_CONCURRENT_QUOTES=6

# Profit and risk filters
ARB_MIN_PROFIT_BPS=20
ARB_MIN_PROFIT_ATOMIC=100000
ARB_SLIPPAGE_BPS=30

# Compute and priority fee
ARB_COMPUTE_UNIT_LIMIT=1000000
ARB_COMPUTE_UNIT_PRICE_MICROLAMPORTS=5000
ARB_CONFIRMATION_COMMITMENT=confirmed

# Comma separated DEX labels accepted by Jupiter for filtering
ARB_DEXES=Raydium,Orca

# Example routes (atomic amounts)
# SOL=So11111111111111111111111111111111111111112
# USDC=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# USDT=Es9vMFrzaCERmJfrF4H2FYD8Vw9xQj2iX8GZF9dgNpQ
ARB_ROUTES_JSON=[{"name":"SOL-USDC-SOL","baseMint":"So11111111111111111111111111111111111111112","midMint":"EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v","tradeAmountAtomic":"200000000"},{"name":"SOL-USDT-SOL","baseMint":"So11111111111111111111111111111111111111112","midMint":"Es9vMFrzaCERmJfrF4H2FYD8Vw9xQj2iX8GZF9dgNpQ","tradeAmountAtomic":"200000000"}]

# Logging
ARB_LOG_FILE=.data/solana-arb.log
ARB_METRICS_FILE=.data/solana-arb-metrics.ndjson

# Wallets
# Single wallet (JSON array of bytes)
SOLANA_PRIVATE_KEY_JSON=

# Multiple wallets (array of JSON byte arrays) - takes precedence if set
# SOLANA_PRIVATE_KEYS_JSON=[[1,2,3,...],[4,5,6,...]]
SOLANA_PRIVATE_KEYS_JSON=
