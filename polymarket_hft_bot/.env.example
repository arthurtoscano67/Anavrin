BOT_MODE=paper

# Polymarket endpoints
CLOB_HOST=https://clob.polymarket.com
CLOB_WS_MARKET_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_MARKETS_URL=https://gamma-api.polymarket.com/markets

# Discovery universe
BTC_MARKET_LIMIT=150
ONLY_15M_MARKETS=true
GAMMA_PAGE_SIZE=200

# Prediction source
# If empty, bot uses an internal short-horizon BTC model based on Binance 1m candles.
FORECAST_ENDPOINT=
FORECAST_POLL_MS=1000
FORECAST_TIMEOUT_MS=300

# Signal thresholds
MIN_EDGE=0.003
FEE_BUFFER=0.0012
SLIPPAGE_BUFFER=0.0008
EXPECTED_15M_VOLATILITY=0.0045
PRICE_FLOOR=0.03
PRICE_CEILING=0.97

# Throughput + risk
MAX_ORDER_USDC=12
MAX_POSITION_USDC=300
MAX_ORDERS_PER_SECOND=50
PER_TOKEN_COOLDOWN_MS=150
STRATEGY_WORKERS=6
EXECUTION_WORKERS=4
STALE_QUOTE_MS=1500
STALE_FORECAST_MS=2500
REST_FALLBACK_ENABLED=true
REST_FALLBACK_POLL_MS=500
REST_FALLBACK_BATCH_SIZE=40

# Adaptation
AUTO_ADAPT=true
ADAPT_EVERY_TRADES=30
MIN_EDGE_FLOOR=0.0015
MIN_EDGE_CAP=0.012

# Paper mode
PAPER_STARTING_CASH=5000
PAPER_FILL_BPS=1.0

# Live mode credentials
CHAIN_ID=137
SIGNATURE_TYPE=2
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

VERBOSE_LOGS=true
